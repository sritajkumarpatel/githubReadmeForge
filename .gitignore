# ─── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.so
*.egg-info/
*.egg
dist/
build/
eggs/
*.whl
.python-version

# ─── Virtual Environments ─────────────────────────────────────────────────────
venv/
.venv/
env/
ENV/

# ─── Environment Variables ────────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ─── Logs ─────────────────────────────────────────────────────────────────────
*.log
server.log

# ─── Testing & Coverage ───────────────────────────────────────────────────────
.coverage
.coverage.*
htmlcov/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.tox/

# ─── IDEs & Editors ───────────────────────────────────────────────────────────
.vscode/
.idea/
.cursor/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# ─── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
**/.DS_Store
Thumbs.db

# ─── Generated Output (runtime artifacts, never commit) ───────────────────────
readme_forge_output/*
!readme_forge_output/.gitkeep
.readme_forge_draft*
# Auto-generated assets go in assets/readme/ (ignored); user-provided demo
# assets at the root of assets/ (e.g. demo.gif, screenshot.png) are intentional
# and should be committed.
assets/*
!assets/.gitkeep
!assets/demo.gif
!assets/demo.mp4
!assets/screenshot.png
!assets/screenshot-light.png
!assets/screenshot-dark.png
showroom.html
README_new.md

# ─── Temporary Clone Directories ──────────────────────────────────────────────
/tmp/readme_forge_clone_*
readme_forge_clone_*/
