# ============================================================
# githubReadmeForge — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values for your setup.
# Only ONE LLM provider is required. The tool auto-detects
# which provider to use based on which key is set.
# ============================================================

# --- LLM Provider Selection (optional) ----------------------
# Override auto-detection. Options: gemini, openai, claude, ollama, mock
# README_FORGE_PROVIDER=gemini

# Override default model name for the selected provider
# README_FORGE_MODEL=gemini-1.5-flash

# --- Google Gemini -------------------------------------------
# Default provider. Get your key at https://aistudio.google.com/
GEMINI_API_KEY=

# --- OpenAI --------------------------------------------------
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# --- Anthropic Claude ----------------------------------------
# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# --- Ollama (Local) ------------------------------------------
# For fully offline/local generation. Install from https://ollama.ai
# OLLAMA_HOST=http://localhost:11434

# --- Server Configuration -----------------------------------
# Port for the web dashboard (default: 8082)
# SERVER_PORT=8082
